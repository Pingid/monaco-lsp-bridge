{
  "name": "monaco-lsp-bridge",
  "version": "0.0.4",
  "description": "Lightweight Monaco–LSP bridge with JSON-RPC transport",
  "author": "Dan Beaven <dm.beaven@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingid/monaco-lsp-bridge.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "package.json",
    "!**/*.test.*",
    "!src/test-utils.ts",
    "tsconfig.json"
  ],
  "keywords": [
    "monaco",
    "lsp",
    "language-server",
    "json-rpc",
    "editor",
    "diagnostics",
    "completion",
    "hover",
    "formatting"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "test": "vitest run 'src'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.18.0"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.35.0"
  },
  "devDependencies": {
    "monaco-editor": "^0.55.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "all"
  }
}
